DATABASE_URL=postgresql://postgres:postgres@localhost:5432/monolito
JWT_SECRET=change-me-in-production
OTEL_ENABLED=false

# Grafana Cloud OTLP (preencher quando configurar Grafana Cloud)
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic YOUR_GRAFANA_TOKEN
