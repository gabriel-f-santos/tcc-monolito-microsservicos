@startuml c4-container-monolith
!include <C4/C4_Container>
LAYOUT_LEFT_RIGHT()

title Arquitetura do sistema monolitico

Person(operador, "Operador")

System_Boundary(aws, "AWS us-east-1") {

    Container(alb, "Load Balancer", "AWS ALB", "HTTPS / health check")

    Container(app, "Aplicacao FastAPI", "EC2 t3.micro + Auto Scaling\nDocker 512MB — Python 3.13", "Monolito com 3 modulos internos:\n• auth (Usuario)\n• catalogo (Produto, Categoria)\n• estoque (Item, Movimentacao)\nCada modulo com camadas\nPresentation / Application / Domain / Infrastructure")

    ContainerDb(rds, "PostgreSQL 16", "RDS db.t4g.micro", "Todas as tabelas no mesmo banco:\nusuarios, produtos, categorias,\nitens_estoque, movimentacoes")
}

Rel(operador, alb, "HTTPS")
Rel(alb, app, "HTTP :8080")
Rel(app, rds, "SQL (SQLAlchemy)")

@enduml
