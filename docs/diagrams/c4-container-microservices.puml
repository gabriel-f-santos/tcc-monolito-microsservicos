@startuml c4-container-microservices
!include <C4/C4_Container>

title Diagrama de Container - Microsservicos Serverless (Lambda + DynamoDB)

Person(operador, "Operador")

System_Boundary(aws, "AWS us-east-1") {

    Container(apigw, "API Gateway", "AWS", "Roteia HTTPS para Lambdas\n/catalogo/* e /estoque/*")

    System_Boundary(catalogo_svc, "Catalogo Service (Bounded Context)") {
        Container(lambda_cat, "Lambda Handlers", "Python 3.13 / 512MB", "health, auth, produtos, categorias")
        Container(uc_cat, "Use Cases", "Python", "CriarProduto, CriarCategoria\nLogin, Registrar")
        Container(domain_cat, "Domain", "Python", "Produto, Categoria, Usuario\nSKU, Dinheiro")
        Container(repo_cat, "DynamoDB Repos", "boto3", "ProdutoRepository\nCategoriaRepository\nUsuarioRepository")
    }

    System_Boundary(estoque_svc, "Estoque Service (Bounded Context)") {
        Container(lambda_est, "Lambda Handlers", "Python 3.13 / 512MB", "health, estoque, movimentacoes")
        Container(lambda_consumer, "Event Consumer", "Python 3.13 / 512MB", "Consome SQS\nCria/atualiza projecao")
        Container(uc_est, "Use Cases", "Python", "RegistrarEntrada\nRegistrarSaida")
        Container(domain_est, "Domain", "Python", "ItemEstoque, Movimentacao\nQuantidade, TipoMovimentacao")
        Container(repo_est, "DynamoDB Repos", "boto3", "ItemEstoqueRepository\nMovimentacaoRepository")
    }

    ContainerDb(dynamo_cat, "DynamoDB", "PAY_PER_REQUEST", "prod-produtos\nprod-categorias\nprod-usuarios")
    ContainerDb(dynamo_est, "DynamoDB", "PAY_PER_REQUEST", "prod-itens-estoque\nprod-movimentacoes")
    ContainerQueue(sns, "SNS Topic", "prod-eventos-dominio", "Fan-out de eventos")
    ContainerQueue(sqs, "SQS Queue", "prod-estoque-eventos", "Buffer de consumo")
}

Rel(operador, apigw, "HTTPS")
Rel(apigw, lambda_cat, "Invoca")
Rel(apigw, lambda_est, "Invoca")
Rel(lambda_cat, uc_cat, "Chama")
Rel(uc_cat, domain_cat, "Usa")
Rel(uc_cat, repo_cat, "Persiste")
Rel(repo_cat, dynamo_cat, "DynamoDB API")
Rel(uc_cat, sns, "Publica evento")
Rel(sns, sqs, "Encaminha")
Rel(sqs, lambda_consumer, "Dispara")
Rel(lambda_consumer, uc_est, "Chama")
Rel(lambda_est, uc_est, "Chama")
Rel(uc_est, domain_est, "Usa")
Rel(uc_est, repo_est, "Persiste")
Rel(repo_est, dynamo_est, "DynamoDB API")

@enduml
