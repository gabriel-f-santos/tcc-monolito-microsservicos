@startuml c4-container-microservices
!include <C4/C4_Container>

title Diagrama de Container - Microsservicos Serverless (Lambda + DynamoDB)

Person(operador, "Operador")

System_Boundary(aws, "AWS us-east-1") {

    Container(apigw, "API Gateway", "AWS", "Roteia HTTPS para Lambdas\nAuthorizer JWT por servico")

    System_Boundary(auth_svc, "Auth Service (Bounded Context)") {
        Container(lambda_auth, "Lambda Handlers", "Python 3.13 / 512MB", "registrar, login, authorizer")
        ContainerDb(dynamo_auth, "DynamoDB", "PAY_PER_REQUEST", "tcc-ddd-auth-usuarios")
    }

    System_Boundary(catalogo_svc, "Catalogo Service (Bounded Context)") {
        Container(lambda_cat, "Lambda Handler", "Python 3.13 / 512MB", "categorias, produtos\nRoteamento por method+path")
        Container(domain_cat, "Domain + Application", "Python puro", "Produto, Categoria, SKU, Dinheiro\nCriarProduto, CriarCategoria")
        Container(infra_cat, "Infrastructure", "boto3", "DynamoDBProdutoRepo\nDynamoDBCategoriaRepo\nSnsEventPublisher")
        ContainerDb(dynamo_cat, "DynamoDB", "PAY_PER_REQUEST", "tcc-ddd-catalogo-produtos\ntcc-ddd-catalogo-categorias")
    }

    System_Boundary(estoque_svc, "Estoque Service (Bounded Context)") {
        Container(lambda_est, "Lambda Handler", "Python 3.13 / 512MB", "estoque, movimentacoes\nalertas")
        Container(lambda_consumer, "Event Consumer", "Python 3.13 / 512MB", "Consome SQS\nCria/atualiza projecao")
        Container(domain_est, "Domain + Application", "Python puro", "ItemEstoque, Movimentacao\nRegistrarEntrada, RegistrarSaida")
        Container(infra_est, "Infrastructure", "boto3", "DynamoDBItemEstoqueRepo\nDynamoDBMovimentacaoRepo\nDynamoDBAlertaEstoqueRepo")
        ContainerDb(dynamo_est, "DynamoDB", "PAY_PER_REQUEST", "tcc-ddd-estoque-itens\ntcc-ddd-estoque-movimentacoes\ntcc-ddd-estoque-alertas")
    }

    ContainerQueue(sns, "SNS Topic", "tcc-ddd-catalogo-eventos", "Fan-out de eventos\nProdutoCriado, ProdutoAtualizado\nProdutoDesativado")
    ContainerQueue(sqs, "SQS Queue", "tcc-ddd-estoque-eventos", "Buffer de consumo\nBatchSize=1, Visibility=180s")
}

Rel(operador, apigw, "HTTPS")
Rel(apigw, lambda_auth, "Invoca (auth)")
Rel(apigw, lambda_cat, "Invoca (catalogo)")
Rel(apigw, lambda_est, "Invoca (estoque)")
Rel(lambda_auth, dynamo_auth, "DynamoDB API")
Rel(lambda_cat, domain_cat, "Delega")
Rel(domain_cat, infra_cat, "Persiste")
Rel(infra_cat, dynamo_cat, "DynamoDB API")
Rel(infra_cat, sns, "Publica evento")
Rel(sns, sqs, "Encaminha")
Rel(sqs, lambda_consumer, "Dispara")
Rel(lambda_consumer, domain_est, "Delega")
Rel(lambda_est, domain_est, "Delega")
Rel(domain_est, infra_est, "Persiste")
Rel(infra_est, dynamo_est, "DynamoDB API")

@enduml
