@startuml c4-container-microservices
!include <C4/C4_Container>

title Arquitetura dos microsservicos serverless

Person(operador, "Operador")

System_Boundary(aws, "AWS us-east-1") {

    Container(apigw, "API Gateway", "AWS + JWT Authorizer", "Roteia para 3 servicos")

    System_Boundary(auth_bc, "Auth Service") {
        Container(auth, "Lambda", "Python 3.13 / 512MB", "Presentation\nApplication\nDomain (Usuario)\nInfrastructure")
        ContainerDb(dynamo_auth, "DynamoDB", "PAY_PER_REQUEST", "usuarios")
    }

    System_Boundary(cat_bc, "Catalogo Service") {
        Container(cat, "Lambda", "Python 3.13 / 512MB", "Presentation\nApplication\nDomain (Produto, Categoria)\nInfrastructure")
        ContainerDb(dynamo_cat, "DynamoDB", "PAY_PER_REQUEST", "produtos, categorias")
    }

    System_Boundary(est_bc, "Estoque Service") {
        Container(est, "Lambda", "Python 3.13 / 512MB", "Presentation + Consumer\nApplication\nDomain (Item, Movimentacao)\nInfrastructure")
        ContainerDb(dynamo_est, "DynamoDB", "PAY_PER_REQUEST", "itens_estoque\nmovimentacoes, alertas")
    }
}

Rel(operador, apigw, "HTTPS")
Rel(apigw, auth, "Invoca")
Rel(apigw, cat, "Invoca")
Rel(apigw, est, "Invoca")
Rel(auth, dynamo_auth, "boto3")
Rel(cat, dynamo_cat, "boto3")
Rel(est, dynamo_est, "boto3")
Rel_R(cat, est, "SNS → SQS", "Eventos de dominio (async)")

Lay_R(auth_bc, cat_bc)
Lay_R(cat_bc, est_bc)

@enduml
