@startuml sequence-stock-exit
title Saida de Estoque - Invariante de Saldo (ambas arquiteturas)

actor Operador
participant "Apresentacao\n(Route ou Lambda)" as handler
participant "Auth" as auth
participant "RegistrarSaida\nUseCase" as uc
participant "ItemEstoque\nAggregate" as item
participant "Movimentacao\nEntity" as mov
participant "ItemEstoqueRepo" as repo
database "Banco\n(PG ou DynamoDB)" as db

Operador -> handler: POST /api/v1/estoque/{id}/saida\n{ quantidade: 30, motivo: "Venda" }
activate handler

handler -> auth: Validar JWT
auth --> handler: OK

handler -> uc: execute(item_id, quantidade=30, motivo)
activate uc

uc -> repo: get_by_id(item_id)
activate repo
repo -> db: SELECT / GetItem
db --> repo: ItemEstoque(saldo=50)
deactivate repo

uc -> item: registrar_saida(quantidade=30)
activate item

alt saldo >= quantidade (50 >= 30)
    item -> item: saldo = saldo - quantidade\nsaldo = 50 - 30 = 20
    item -> mov: Movimentacao(tipo=SAIDA, quantidade=30)
    item --> uc: OK (saldo atualizado = 20)
else saldo < quantidade
    item --> uc: raise EstoqueInsuficiente\n(saldo_atual=50, solicitado=80)
    note right: Invariante protegida\nDENTRO do agregado\nnao no use case
end

deactivate item

uc -> repo: salvar(item)
activate repo
repo -> db: UPDATE / PutItem
db --> repo: OK
deactivate repo

uc --> handler: MovimentacaoResponse
deactivate uc

handler --> Operador: 201 Created
deactivate handler

@enduml
